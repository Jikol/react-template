server {
  listen ${_WEBAPP_HTTP_PORT} default_server;
  listen [::]:$_WEBAPP_HTTP_PORT default_server;

  return 302 https://$host:$_WEBAPP_HTTPS_PORT$request_uri;
}

server {
  listen ${_WEBAPP_HTTPS_PORT} ssl default_server;
  listen [::]:$_WEBAPP_HTTPS_PORT ssl default_server;

  root /var/www;
  index index.html;

  ssl_certificate ${_WEBAPP_SSL_CERT_PATH};
  ssl_certificate_key ${_WEBAPP_SSL_KEY_PATH};

  location / {
    try_files $uri $uri/ =404;
  }
}
