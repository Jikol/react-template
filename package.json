{
  "name": "react-template",
  "private": true,
  "type": "module",
  "author": "Ondřej Javorský",
  "license": "MIT",
  "readme": "README.md",
  "scripts": {
    "dev": "bunx --bun vite",
    "prev": "bun prod && bunx --bun vite preview",
    "prod": "bunx --bun rimraf dist && bunx --bun vite build",
    "lint": "bunx --bun eslint . --fix && bunx --bun stylelint **/*.css --fix && echo 'Success! No lint errors or warnings' | chalk --stdin green",
    "form": "bunx --bun prettier . -w && bunx --bun stylelint **/*.css --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@ctrl/tinycolor": "^4.2.0",
